SLATEFS_DEMO_HOST=127.0.0.1
SLATEFS_DEMO_PORT=4174
SLATEFS_DEMO_SECURE_COOKIE=false
SLATEFS_CONSUMER_BASE_URL=http://127.0.0.1:9410
SLATEFS_ADMIN_BASE_URL=http://127.0.0.1:9400
SLATEFS_DEMO_STATIC_DIR=/absolute/path/to/web/apps/demo/dist
# Set either TOKEN or TOKEN_FILE for each tenant. Never expose these to Vite/public env.
SLATEFS_ACME_TOKEN_FILE=/absolute/server-only/path/acme.token
SLATEFS_GLOBEX_TOKEN_FILE=/absolute/server-only/path/globex.token
